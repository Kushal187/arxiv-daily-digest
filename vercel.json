{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "npm install",
  "buildCommand": "npm --workspace apps/web run build",
  "outputDirectory": "apps/web/.next",
  "rewrites": [
    {
      "source": "/internal/(.*)",
      "destination": "/api/worker"
    }
  ]
}
