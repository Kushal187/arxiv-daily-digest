{
  "name": "arxiv-daily-digest",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "dev:worker": "python3 -m uvicorn app.main:app --app-dir apps/worker --reload",
    "test:worker": "python3 -m unittest discover apps/worker/tests",
    "test": "npm run test:worker"
  }
}
